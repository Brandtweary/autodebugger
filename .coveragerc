[run]
parallel = True
concurrency = multiprocessing
source = autodebugger

[paths]
source =
    autodebugger/
    */site-packages/autodebugger/

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass

[html]
directory = coverage_html
